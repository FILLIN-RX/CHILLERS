{
  "name": "chiller-backend",
  "version": "1.0.0",
  "description": "Chiller streaming platform backend - Secure gateway to TMDB API",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "preview": "node dist/server.js",
    "upload": "npx tsx src/scripts/upload-doodstream.ts",
    "upload-series": "npx tsx src/scripts/upload-series-doodstream.ts",
    "organize-series": "npx tsx src/scripts/organize-series.ts",
    "check-status": "npx tsx src/scripts/check-upload-status.ts"
  },
  "keywords": [
    "chiller",
    "streaming",
    "tmdb",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^7.2.0",
    "morgan": "^1.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
