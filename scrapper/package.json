{
  "name": "chiller-scrapper",
  "version": "1.0.0",
  "description": "Standalone scraper service for Chiller - scraping + dead link maintenance",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape:films": "npx tsx src/scraping/scrape-films.ts",
    "scrape:series": "npx tsx src/scraping/scrape-series.ts",
    "maintenance": "npx tsx src/maintenance/maintainer.ts",
    "link:movies": "npx tsx src/maintenance/link-movies-tmdb.ts",
    "link:series": "npx tsx src/maintenance/link-series-tmdb.ts"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "node-cron": "^4.6.0",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
